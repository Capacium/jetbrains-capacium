<idea-plugin>
    <id>xyz.capacium.jetbrains-capacium</id>
    <name>Capacium</name>
    <vendor email="hello@capacium.xyz" url="https://capacium.xyz">Capacium</vendor>
    <description><![CDATA[
        Search and install AI agent capabilities from the Capacium marketplace.
        Browse skills, MCP servers, workflows, and tools — with trust state verification.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Capacium" anchor="right" icon="AllIcons.Actions.Search"
                    factoryClass="xyz.capacium.CapaciumToolWindowFactory"/>
    </extensions>

    <actions>
        <action id="Capacium.SearchAction" class="xyz.capacium.SearchAction"
                text="Search Capacium Marketplace" description="Search the Capacium marketplace">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
